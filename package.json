{
  "name": "jpg-to-ascii",
  "private": true,
  "version": "1.2.0",
  "description": "JPG to ASCII converter",
  "main": "./src/server.ts",
  "scripts": {
    "start": "tsx ./src/server.ts",
    "dev": "concurrently -n webpack,node -c green,blue \"webpack --watch\" \"tsx watch ./src/server.ts\"",
    "build": "webpack",
    "lint": "oxlint src/ public/js/",
    "format": "oxfmt --write src/ public/js/ webpack.config.js"
  },
  "keywords": [
    "image",
    "ascii",
    "art",
    "converter"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "Volodymyr Zakhovaiko",
  "license": "ISC",
  "dependencies": {
    "express": "5.2.1",
    "multer": "2.1.1",
    "sharp": "0.34.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"]
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "25.6.0",
    "concurrently": "9.2.1",
    "css-loader": "7.1.4",
    "mini-css-extract-plugin": "2.10.2",
    "nodemon": "3.1.14",
    "oxfmt": "0.46.0",
    "oxlint": "1.62.0",
    "sass": "1.99.0",
    "sass-loader": "16.0.7",
    "ts-loader": "9.5.7",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2"
  }
}
